<?xml version="1.0" encoding="utf-8"?>
<!--
  Simplified SMPL-X Humanoid URDF for Kick-Boxing RL
  22 joints matching SMPL-X kinematic tree (subset relevant for combat)
  Joint order follows SMPL-X convention: pelvis as root

  Capsule convention: long axis = local Z.
    - Leg capsules extend along Z (no rotation needed)
    - Arm capsules extend along X, so rpy="0 1.5708 0" rotates local Z -> X
-->
<robot name="smplx_humanoid">

  <!-- ==================== MATERIALS ==================== -->
  <material name="skin">
    <color rgba="0.87 0.72 0.53 1.0"/>
  </material>
  <material name="joint_color">
    <color rgba="0.3 0.3 0.8 1.0"/>
  </material>
  <material name="glove">
    <color rgba="0.7 0.15 0.15 1.0"/>
  </material>

  <!-- ==================== PELVIS (ROOT) ==================== -->
  <link name="pelvis">
    <inertial>
      <mass value="11.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.07" ixy="0" ixz="0" iyy="0.07" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry><box size="0.22 0.15 0.18"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <geometry><box size="0.22 0.15 0.18"/></geometry>
    </collision>
  </link>

  <!-- ==================== SPINE CHAIN ==================== -->
  <link name="spine1">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry><box size="0.20 0.14 0.20"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1"/>
      <geometry><box size="0.20 0.14 0.20"/></geometry>
    </collision>
  </link>

  <joint name="spine1_joint" type="spherical">
    <parent link="pelvis"/>
    <child link="spine1"/>
    <origin xyz="0 0 0.09"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="spine2">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.03"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry><box size="0.22 0.15 0.20"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1"/>
      <geometry><box size="0.22 0.15 0.20"/></geometry>
    </collision>
  </link>

  <joint name="spine2_joint" type="spherical">
    <parent link="spine1"/>
    <child link="spine2"/>
    <origin xyz="0 0 0.20"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="spine3">
    <inertial>
      <mass value="7.0"/>
      <origin xyz="0 0 0.08"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.025"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.08"/>
      <geometry><box size="0.24 0.15 0.16"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08"/>
      <geometry><box size="0.24 0.15 0.16"/></geometry>
    </collision>
  </link>

  <joint name="spine3_joint" type="spherical">
    <parent link="spine2"/>
    <child link="spine3"/>
    <origin xyz="0 0 0.20"/>
    <dynamics damping="5.0"/>
  </joint>

  <!-- ==================== NECK / HEAD ==================== -->
  <link name="neck">
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
    </collision>
  </link>

  <joint name="neck_joint" type="spherical">
    <parent link="spine3"/>
    <child link="neck"/>
    <origin xyz="0 0 0.16"/>
    <dynamics damping="2.0"/>
  </joint>

  <link name="head">
    <inertial>
      <mass value="4.5"/>
      <origin xyz="0 0 0.08"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.015"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.08"/>
      <geometry><sphere radius="0.10"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08"/>
      <geometry><sphere radius="0.10"/></geometry>
    </collision>
  </link>

  <joint name="head_joint" type="spherical">
    <parent link="neck"/>
    <child link="head"/>
    <origin xyz="0 0 0.10"/>
    <dynamics damping="1.0"/>
  </joint>

  <!-- ==================== LEFT ARM ==================== -->
  <!--
    Chain: spine3 --(shoulder)--> upper_arm (0.28m) --(elbow)--> forearm (0.24m) --(wrist)--> hand
    Capsules rotated rpy="0 1.5708 0" so long axis (Z) points along +X
  -->
  <link name="left_upper_arm">
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0.14 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.14 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.045" length="0.28"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0.14 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.045" length="0.28"/></geometry>
    </collision>
  </link>

  <joint name="left_shoulder" type="spherical">
    <parent link="spine3"/>
    <child link="left_upper_arm"/>
    <origin xyz="0.18 0 0.12"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="left_forearm">
    <inertial>
      <mass value="1.8"/>
      <origin xyz="0.12 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.012"/>
    </inertial>
    <visual>
      <origin xyz="0.12 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.035" length="0.24"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0.12 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.035" length="0.24"/></geometry>
    </collision>
  </link>

  <joint name="left_elbow" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_forearm"/>
    <origin xyz="0.28 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.6" effort="150" velocity="10"/>
    <dynamics damping="2.0"/>
  </joint>

  <link name="left_hand">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.035 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0.035 0 0"/>
      <geometry><sphere radius="0.045"/></geometry>
      <material name="glove"/>
    </visual>
    <collision>
      <origin xyz="0.035 0 0"/>
      <geometry><sphere radius="0.045"/></geometry>
    </collision>
  </link>

  <joint name="left_wrist" type="spherical">
    <parent link="left_forearm"/>
    <child link="left_hand"/>
    <origin xyz="0.24 0 0"/>
    <dynamics damping="1.5"/>
  </joint>

  <!-- ==================== RIGHT ARM ==================== -->
  <link name="right_upper_arm">
    <inertial>
      <mass value="2.5"/>
      <origin xyz="-0.14 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="-0.14 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.045" length="0.28"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="-0.14 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.045" length="0.28"/></geometry>
    </collision>
  </link>

  <joint name="right_shoulder" type="spherical">
    <parent link="spine3"/>
    <child link="right_upper_arm"/>
    <origin xyz="-0.18 0 0.12"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="right_forearm">
    <inertial>
      <mass value="1.8"/>
      <origin xyz="-0.12 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.012"/>
    </inertial>
    <visual>
      <origin xyz="-0.12 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.035" length="0.24"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="-0.12 0 0" rpy="0 1.5708 0"/>
      <geometry><capsule radius="0.035" length="0.24"/></geometry>
    </collision>
  </link>

  <joint name="right_elbow" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_forearm"/>
    <origin xyz="-0.28 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="0" effort="150" velocity="10"/>
    <dynamics damping="2.0"/>
  </joint>

  <link name="right_hand">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="-0.035 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="-0.035 0 0"/>
      <geometry><sphere radius="0.045"/></geometry>
      <material name="glove"/>
    </visual>
    <collision>
      <origin xyz="-0.035 0 0"/>
      <geometry><sphere radius="0.045"/></geometry>
    </collision>
  </link>

  <joint name="right_wrist" type="spherical">
    <parent link="right_forearm"/>
    <child link="right_hand"/>
    <origin xyz="-0.24 0 0"/>
    <dynamics damping="1.5"/>
  </joint>

  <!-- ==================== LEFT LEG ==================== -->
  <!-- Leg capsules: long axis = Z (default), extending downward = correct -->
  <link name="left_hip_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.055"/></geometry>
      <material name="joint_color"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.055"/></geometry>
    </collision>
  </link>

  <joint name="left_hip" type="spherical">
    <parent link="pelvis"/>
    <child link="left_hip_link"/>
    <origin xyz="0.09 0 -0.09"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="left_upper_leg">
    <inertial>
      <mass value="7.0"/>
      <origin xyz="0 0 -0.21"/>
      <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.015"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.21"/>
      <geometry><capsule radius="0.055" length="0.42"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.21"/>
      <geometry><capsule radius="0.055" length="0.42"/></geometry>
    </collision>
  </link>

  <joint name="left_hip_extend" type="fixed">
    <parent link="left_hip_link"/>
    <child link="left_upper_leg"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="left_lower_leg">
    <inertial>
      <mass value="4.5"/>
      <origin xyz="0 0 -0.20"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.20"/>
      <geometry><capsule radius="0.045" length="0.40"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.20"/>
      <geometry><capsule radius="0.045" length="0.40"/></geometry>
    </collision>
  </link>

  <joint name="left_knee" type="revolute">
    <parent link="left_upper_leg"/>
    <child link="left_lower_leg"/>
    <origin xyz="0 0 -0.42"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.8" upper="0" effort="200" velocity="12"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="left_foot">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0.04 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <origin xyz="0 0.04 0"/>
      <geometry><box size="0.08 0.22 0.04"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0.04 0"/>
      <geometry><box size="0.08 0.22 0.04"/></geometry>
    </collision>
  </link>

  <joint name="left_ankle" type="spherical">
    <parent link="left_lower_leg"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.40"/>
    <dynamics damping="2.0"/>
  </joint>

  <!-- ==================== RIGHT LEG ==================== -->
  <link name="right_hip_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.055"/></geometry>
      <material name="joint_color"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.055"/></geometry>
    </collision>
  </link>

  <joint name="right_hip" type="spherical">
    <parent link="pelvis"/>
    <child link="right_hip_link"/>
    <origin xyz="-0.09 0 -0.09"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="right_upper_leg">
    <inertial>
      <mass value="7.0"/>
      <origin xyz="0 0 -0.21"/>
      <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.015"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.21"/>
      <geometry><capsule radius="0.055" length="0.42"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.21"/>
      <geometry><capsule radius="0.055" length="0.42"/></geometry>
    </collision>
  </link>

  <joint name="right_hip_extend" type="fixed">
    <parent link="right_hip_link"/>
    <child link="right_upper_leg"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="right_lower_leg">
    <inertial>
      <mass value="4.5"/>
      <origin xyz="0 0 -0.20"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.20"/>
      <geometry><capsule radius="0.045" length="0.40"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.20"/>
      <geometry><capsule radius="0.045" length="0.40"/></geometry>
    </collision>
  </link>

  <joint name="right_knee" type="revolute">
    <parent link="right_upper_leg"/>
    <child link="right_lower_leg"/>
    <origin xyz="0 0 -0.42"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.8" upper="0" effort="200" velocity="12"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="right_foot">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0.04 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <origin xyz="0 0.04 0"/>
      <geometry><box size="0.08 0.22 0.04"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0 0.04 0"/>
      <geometry><box size="0.08 0.22 0.04"/></geometry>
    </collision>
  </link>

  <joint name="right_ankle" type="spherical">
    <parent link="right_lower_leg"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.40"/>
    <dynamics damping="2.0"/>
  </joint>

</robot>
